{
    "name": "react-shop",
    "private": true,
    "version": "0.0.0",
    "type": "module",
    "scripts": {
        "start": "podman run -d --replace --name react-shop -p 3000:3000 -p 4000:4000 react-shop && podman logs -f react-shop",
        "dev": "vite",
