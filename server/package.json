{
    "name": "shoprea-server",
    "private": true,
    "version": "0.0.0",
    "type": "module",
    "scripts": {
        "start": "podman build -t shoprea-server . && ./scripts/podman.sh",
        "init": "podman build -t shoprea-server .",
        "shell": "podman exec -it shoprea-server /bin/bash",
        "dev": "vite",
        "preview": "vite preview",
        "build": "tsc -b && vite build",
        "lint": "eslint .",
        "server": "NODE_PATH=/app/node_modules nodemon src/server.ts",
        "generate": "prisma generate",
        "migrate": "prisma migrate dev"
    },
    "dependencies": {
        "@paypal/paypal-server-sdk": "^2.2.0",
        "@prisma/adapter-better-sqlite3": "^7.4.0",
        "@prisma/client": "^7.4.0",
        "@types/express-fileupload": "^1.5.1",
        "better-sqlite3": "^12.6.2",
        "cors": "^2.8.6",
        "country-state-city": "^3.2.1",
        "dotenv": "^17.3.1",
        "express": "^5.2.1",
        "express-fileupload": "^1.5.2",
        "js-cookie": "^3.0.5",
        "js-sha256": "^0.11.1",
        "prisma": "^7.4.0",
        "vite-plugin-compression2": "^2.5.3"
    },
    "devDependencies": {
        "@eslint/js": "^9.39.1",
        "@types/better-sqlite3": "^7.6.13",
        "@types/express": "^5.0.6",
        "@types/node": "^24.10.1",
        "eslint": "^9.39.1",
        "globals": "^16.5.0",
        "nodemon": "^3.1.9",
        "typescript": "~5.9.3",
        "typescript-eslint": "^8.48.0",
        "vite": "^7.3.1"
    }
}
